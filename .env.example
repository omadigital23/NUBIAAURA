# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_MEDIA_BUCKET=media
ADMIN_TOKEN=your_admin_token

# Image URL rewrite for withImageParams (Supabase public base & bucket)
NEXT_PUBLIC_IMAGE_BASE=
NEXT_PUBLIC_IMAGE_BUCKET=products

# Flutterwave (Payments)
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_ENCRYPTION_KEY=your_flutterwave_encryption_key

# CallMeBot (WhatsApp Notifications - GRATUIT)
# 1. Ajouter +34 644 28 04 85 sur WhatsApp
# 2. Envoyer: "I allow callmebot to send me messages"
# 3. Copier l'API key reçue
CALLMEBOT_API_KEY=your_callmebot_api_key
MANAGER_WHATSAPP=+221771234567

# SendGrid (Email Notifications)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@nubiaaura.com
MANAGER_EMAIL=manager@nubiaaura.com

# Upstash (Rate Limiting)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Sentry (Error Logging)
SENTRY_DSN=your_sentry_dsn

# Admin Credentials (Hashed & Salted - DO NOT SHARE RAW PASSWORDS)
# Generate hash: node scripts/generate-admin-hash.js "your_password"
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD_HASH=your_hashed_password
ADMIN_SALT=your_salt

# App Config
NEXT_PUBLIC_DEFAULT_LANG=fr
NEXT_PUBLIC_SITE_URL=https://www.nubiaaura.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=production