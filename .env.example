# 🔐 NUBIA AURA - Configuration d'Environnement
# Copiez ce fichier vers .env.local et remplissez avec vos vraies clés
# IMPORTANT: Ne jamais committer .env.local dans Git !

# ===========================================
# 🗄️ SUPABASE (Obligatoire)
# ===========================================
# URL de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co

# Clé publique Supabase (visible par le client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service Supabase (privée, serveur uniquement)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Bucket de médias Supabase
NEXT_PUBLIC_SUPABASE_MEDIA_BUCKET=media

# ===========================================
# 🖼️ IMAGES (Configuration)
# ===========================================
# Base URL pour les images Supabase
NEXT_PUBLIC_IMAGE_BASE=
NEXT_PUBLIC_IMAGE_BUCKET=products

# ===========================================
# 💳 FLUTTERWAVE - Paiements (Recommandé)
# ===========================================
# Clé publique Flutterwave
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-XXX...

# Clé secrète Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-XXX...

# Clé de chiffrement Flutterwave (32 caractères)
FLUTTERWAVE_ENCRYPTION_KEY=votre_clé_chiffrement_32_caracteres

# ===========================================
# 📱 WHATSAPP - CallMeBot (GRATUIT)
# ===========================================
# CallMeBot API for WhatsApp notifications
# Get your API key at https://www.callmebot.com/
CALLMEBOT_PHONE=your_whatsapp_phone_number
CALLMEBOT_API_KEY=your_callmebot_api_key

# ===========================================
# 📧 EMAIL - SendGrid (Recommandé)
# ===========================================
# Clé API SendGrid
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Email d'envoi (doit être vérifié sur SendGrid)
SENDGRID_FROM_EMAIL=noreply@nubiaaura.com
MANAGER_EMAIL=manager@nubiaaura.com

# ===========================================
# 🗃️ CACHE - Upstash Redis (Optionnel)
# ===========================================
# URL REST Upstash
UPSTASH_REDIS_REST_URL=https://votre-projet.upstash.io

# Token REST Upstash
UPSTASH_REDIS_REST_TOKEN=votre_token_upstash

# ===========================================
# 📊 MONITORING - Sentry (Optionnel)
# ===========================================
# DSN Sentry pour le logging d'erreurs
SENTRY_DSN=https://XXXXXXXXXXXXX@sentry.io/XXXXXXX

# ===========================================
# 🔑 ADMINISTRATION (Sécurisé)
# ===========================================
# Generate hash: node scripts/generate-admin-hash.js "your_password"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=votre_hash_generé_ici
ADMIN_SALT=votre_salt_ici

# Token admin pour les APIs
ADMIN_TOKEN=votre_token_admin_unique

# ===========================================
# 🔔 CRON - Cleanup automatique (Optionnel)
# ===========================================
# Secret pour sécuriser les endpoints cron
CRON_SECRET=nubia-cleanup-2024-unique-secret-key

# ===========================================
# 🌍 APPLICATION (Configuration)
# ===========================================
# Langue par défaut
NEXT_PUBLIC_DEFAULT_LANG=fr

# URLs de l'application
NEXT_PUBLIC_SITE_URL=https://www.nubiaaura.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=production

# ===========================================
# ⚠️ NOTES DE SÉCURITÉ
# ===========================================
# 1. Gardez .env.local en dehors de Git
# 2. Utilisez des clés fortes et uniques
# 3. Ne partagez jamais les clés service
# 4. Changez les clés régulièrement
# 5. Utilisez des clés différentes en dev/prod