{
  "name": "nubia-aura",
  "version": "1.0.0",
  "description": "Nubia Aura - Plateforme de Mode Africaine Éthique & Sur-Mesure",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit --incremental false",
    "setup": "node scripts/start-nubia.js",
    "seed": "node scripts/setup-supabase.js",
    "fix-apis": "node scripts/fix-checkout-apis.js",
    "test-api": "node scripts/test-apis.js",
    "upload:media": "node scripts/upload-media.js",
    "backfill:product-images": "node scripts/backfill-product-images.js",
    "upsert:products:from-images": "node scripts/upsert-products-from-local-images.js",
    "test:checkout": "node test-checkout.js",
    "test:checkout:cod": "node test-checkout.js --cod",
    "test:checkout:flutterwave": "node test-checkout.js --flutterwave",
    "test:checkout:all": "node test-checkout.js --all",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:integration": "jest __tests__/integration --testTimeout=30000 --runInBand",
    "security:audit": "node scripts/audit-database-security.js",
    "security:generate-secrets": "node scripts/generate-secrets.js",
    "security:rotate-secrets": "node scripts/rotate-secrets.js",
    "security:verify": "node scripts/verify-security.js",
    "generate:admin-hash": "node scripts/generate-admin-hash.js",
    "generate:2fa-secret": "node scripts/generate-2fa-secret.js",
    "configure:vercel": "node scripts/configure-vercel-production.js",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.0",
